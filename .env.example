# CloudShield — Environment Configuration

# Copy this file to backend/.env and fill in your values.
# Never commit the actual .env file to version control.

# ── Core ──────────────────────────────────────────────────────────────────────

# Comma-separated HMAC signing keys for EDR agent authentication
# Rotate by adding a new key to the front; remove old keys after agents update
AGENT_KEYS=your-secret-key-here

# CORS: comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,https://your-vercel-url.vercel.app

# ── AI Risk Engine ─────────────────────────────────────────────────────────────

# OpenAI API key for GPT-4 risk narrative synthesis
# Leave blank to use the built-in rule-based fallback engine
OPENAI_API_KEY=

# ── Database (optional) ────────────────────────────────────────────────────────

# MongoDB connection URI for persistent scan storage
# Leave blank to use in-memory storage (fully functional for demos)
MONGODB_URI=

# ── AWS (optional) ─────────────────────────────────────────────────────────────

# AWS credentials for live S3, EC2, and IAM scanning
# Leave blank to use demo/mock fallback mode
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ── Azure (optional) ───────────────────────────────────────────────────────────

# Azure Storage connection string for live Blob container scanning
AZURE_STORAGE_CONNECTION_STRING=

# ── GCP (optional) ─────────────────────────────────────────────────────────────

# GCP service account credentials as a JSON string (single line)
GCP_CREDENTIALS_JSON=

# ── Email Alerts (optional) ────────────────────────────────────────────────────

# SMTP credentials for SOC email alert notifications
SMTP_USER=
SMTP_PASS=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ── Cloudflare (optional) ──────────────────────────────────────────────────────

# Cloudflare API token and zone ID for automated IP blocking
CF_API_TOKEN=
CF_ZONE_ID=
